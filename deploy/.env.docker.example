# Docker环境变量配置
# 复制此文件为 .env 并修改相应配置

# 应用配置
APP_ENV=development
APP_NAME=MyRAG
APP_VERSION=1.0.0

# MySQL配置
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=myrag
MYSQL_USER=myrag
MYSQL_PASSWORD=myrag123

# Ollama配置
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Neo4j配置
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=myrag123
NEO4J_DATABASE=neo4j

# 后端配置
BACKEND_PORT=8000
BACKEND_WORKERS=1
BACKEND_RELOAD=true

# Nginx配置
NGINX_PORT=80

# 数据持久化路径（相对于项目根目录）
DATA_DIR=./data
MODELS_DIR=./Models
LOGS_DIR=./data/logs
