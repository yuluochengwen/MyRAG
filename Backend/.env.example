# MyRAG 环境变量配置模板
# 复制此文件为 Backend/.env 并根据实际环境修改

# ========== MySQL 数据库 ==========
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=myrag

# ========== 可选: 应用配置 ==========
# APP_ENV=development
# APP_DEBUG=true
# APP_HOST=0.0.0.0
# APP_PORT=8000

# ========== 可选: OpenAI 兼容接口 ==========
# OPENAI_API_KEY=your-api-key-here

# ========== Docker 环境 (取消注释以下内容) ==========
# MYSQL_HOST=mysql
# MYSQL_USER=myrag
# MYSQL_PASSWORD=myrag123
# OLLAMA_BASE_URL=http://ollama:11434
# NEO4J_URI=bolt://neo4j:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=myrag123
# PROJECT_ROOT=/app
